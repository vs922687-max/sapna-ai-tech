{
  "version": 1,
  "sdk_version": "0.24.0",
  "path": "/mcp",
  "auth": {
    "type": "oauth",
    "issuer": "https://ruyguyknhfiusojpayqb.supabase.co/auth/v1",
    "accepted_audiences": [
      "authenticated"
    ]
  },
  "mcp": {
    "server": {
      "name": "bharat-ai-sathi-mcp",
      "version": "0.1.0",
      "title": "Bharat AI Sathi"
    },
    "tools": [
      {
        "name": "whoami",
        "title": "Who am I",
        "description": "Return the signed-in Bharat AI Sathi user's ID and email from the OAuth token.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {}
        },
        "outputSchema": null
      },
      {
        "name": "list_gov_services",
        "title": "List Indian government services",
        "description": "List Indian government services documented on Bharat AI Sathi. Optionally filter by category. Returns slug, name, Hindi name, category, ministry, official website.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "category": {
              "description": "Optional category filter, e.g. Identity, Welfare, Tax.",
              "type": "string"
            },
            "limit": {
              "description": "Max services to return. Defaults to 50.",
              "type": "integer",
              "minimum": -9007199254740991,
              "maximum": 9007199254740991
            }
          }
        },
        "outputSchema": null
      },
      {
        "name": "search_gov_services",
        "title": "Search Indian government services",
        "description": "Search Bharat AI Sathi's Indian government services by keyword (matches name, Hindi name, category, ministry, tagline).",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "query": {
              "type": "string",
              "minLength": 1,
              "description": "Keyword to search for."
            },
            "limit": {
              "description": "Max matches. Defaults to 20.",
              "type": "integer",
              "minimum": -9007199254740991,
              "maximum": 9007199254740991
            }
          },
          "required": [
            "query"
          ]
        },
        "outputSchema": null
      },
      {
        "name": "get_gov_service",
        "title": "Get Indian government service details",
        "description": "Get full details for one Indian government service by slug: eligibility, documents, steps, notes, FAQs, and the official portal URL.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "slug": {
              "type": "string",
              "minLength": 1,
              "description": "Service slug, e.g. 'aadhaar', 'pan-card', 'pmay'."
            }
          },
          "required": [
            "slug"
          ]
        },
        "outputSchema": null
      }
    ]
  }
}
